{
  "name": "pulse-bi",
  "version": "0.1.0",
  "private": false,
  "description": "AI-native business intelligence. Connect data, ask in plain English, and get dashboards that explain themselves — an agent-first, open-source alternative to PowerBI.",
  "license": "MIT",
  "author": "Asray Gopa",
  "homepage": "https://github.com/asrayg/pulse#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asrayg/pulse.git"
  },
  "bugs": {
    "url": "https://github.com/asrayg/pulse/issues"
  },
  "keywords": [
    "business-intelligence",
    "bi",
    "ai",
    "analytics",
    "text-to-sql",
    "dashboards",
    "nextjs",
    "llm",
    "agent",
    "powerbi-alternative"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:demo": "tsx lib/demo/seed-demo.ts",
    "seed:app": "tsx lib/db/seed.ts",
    "setup": "drizzle-kit push --force && pnpm seed:demo && pnpm seed:app"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.86",
    "@radix-ui/react-slot": "^1.3.0",
    "ai": "^6.0.209",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.15",
    "next": "16.2.9",
    "papaparse": "^5.5.4",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "bcryptjs",
      "esbuild"
    ]
  }
}