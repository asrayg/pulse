# --- Pulse environment ---

# App (SQLite) database path
PULSE_DB_PATH=./data/pulse.db

# Demo SaaS dataset path (auto-seeded)
PULSE_DEMO_DB_PATH=./data/demo.db

# Session signing secret (any long random string)
AUTH_SECRET=dev-secret-change-me-to-a-long-random-string

# 32-byte key (base64 or hex) used to encrypt external DB credentials at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PULSE_ENCRYPTION_KEY=

# --- LLM (optional) ---
# Pulse uses the Vercel AI SDK. Provide ONE of the following.
# If none are set, Pulse falls back to a deterministic SQL planner that handles
# the seeded demo questions so the product is fully usable offline.

# Vercel AI Gateway (recommended). Uses "anthropic/claude-..." model strings.
AI_GATEWAY_API_KEY=

# Or a direct Anthropic key
ANTHROPIC_API_KEY=

# Model id (gateway form). Default: anthropic/claude-sonnet-4-6
PULSE_MODEL=anthropic/claude-sonnet-4-6
